# 数据库配置
DATABASE_URL=postgresql://newsuser:newspass@localhost:5432/newsdb

# Google News API (推荐配置，获取地址: https://newsapi.org/register)
# 如果不配置或留空，系统会自动使用备用搜索方案
GOOGLE_NEWS_API_KEY=

# Brave Search API (可选备用方案，获取地址: https://brave.com/search/api/)
BRAVE_API_KEY=

# CORS 配置
CORS_ORIGINS=http://localhost:3000
